generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ImportStatus {
  parsed
  failed
}

enum RouteReviewStatus {
  draft
  in_review
  confirmed
}

enum StopStatus {
  pending
  arrived
  skipped
  issue
}

model DeliveryImport {
  id             String       @id @default(cuid())
  sourceFileName String
  importedAt     DateTime     @default(now())
  rowCount       Int
  status         ImportStatus @default(parsed)
  routes         Route[]
}

model DeliveryDay {
  id          String      @id @default(cuid())
  serviceDate DateTime    @db.Date
  timezone    String      @default("America/Toronto")
  routes      Route[]
  stops       RouteStop[]

  @@unique([serviceDate])
}

model Driver {
  id     String  @id @default(cuid())
  name   String  @unique
  routes Route[]
}

model Route {
  id              String            @id @default(cuid())
  importId        String?
  deliveryDayId   String
  driverId        String?
  routeName       String
  status          RouteReviewStatus @default(draft)
  firstEtaLocal   String?
  lastEtaLocal    String?
  deliveryImport  DeliveryImport?   @relation(fields: [importId], references: [id])
  deliveryDay     DeliveryDay       @relation(fields: [deliveryDayId], references: [id])
  driver          Driver?           @relation(fields: [driverId], references: [id])
  stops           RouteStop[]
  deliveryTips    DeliveryTip[]
  routeReviewLogs RouteReviewLog[]

  @@index([deliveryDayId, routeName])
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  customerName String
  itemSummary  String?
  stops        RouteStop[]
}

model RouteStop {
  id                 String        @id @default(cuid())
  routeId            String
  deliveryDayId      String
  orderId            String?
  sequence           Int
  fullAddress        String
  city               String?
  province           String?
  postalCode         String?
  latitude           Decimal?      @db.Decimal(10, 7)
  longitude          Decimal?      @db.Decimal(10, 7)
  etaLocal           String?
  actualArrivalLocal String?
  timezone           String        @default("America/Toronto")
  deliveryTip        String?
  dispatcherMemo     String?
  status             StopStatus    @default(pending)
  route              Route         @relation(fields: [routeId], references: [id])
  deliveryDay        DeliveryDay   @relation(fields: [deliveryDayId], references: [id])
  order              Order?        @relation(fields: [orderId], references: [id])
  tips               DeliveryTip[]

  @@unique([routeId, sequence])
  @@index([deliveryDayId])
}

model DeliveryTip {
  id                 String     @id @default(cuid())
  stopId             String?
  routeId            String?
  addressFingerprint String
  body               String
  createdAt          DateTime   @default(now())
  stop               RouteStop? @relation(fields: [stopId], references: [id])
  route              Route?     @relation(fields: [routeId], references: [id])

  @@index([addressFingerprint])
}

model RouteReviewLog {
  id        String            @id @default(cuid())
  routeId   String
  status    RouteReviewStatus
  note      String?
  createdAt DateTime          @default(now())
  route     Route             @relation(fields: [routeId], references: [id])
}

model AdminUser {
  id           String          @id @default(cuid())
  username     String          @unique
  passwordHash String
  isActive     Boolean         @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt
  sessions     AdminSession[]
  loginLogs    AdminLoginLog[]
}

model AdminSession {
  id          String          @id @default(cuid())
  adminUserId String          @map("admin_user_id")
  tokenHash   String          @unique @map("token_hash")
  createdAt   DateTime        @default(now()) @map("created_at")
  expiresAt   DateTime        @map("expires_at")
  revokedAt   DateTime?       @map("revoked_at")
  userAgent   String?         @map("user_agent")
  ipAddress   String?         @map("ip_address")
  adminUser   AdminUser       @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  loginLogs   AdminLoginLog[]

  @@index([adminUserId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("admin_sessions")
}

model AdminLoginLog {
  id             String        @id @default(cuid())
  adminUserId    String?       @map("admin_user_id")
  emailAttempted String        @map("email_attempted")
  eventType      String        @map("event_type")
  result         String
  failureReason  String?       @map("failure_reason")
  ipAddress      String?       @map("ip_address")
  userAgent      String?       @map("user_agent")
  sessionId      String?       @map("session_id")
  requestPath    String?       @map("request_path")
  requestMethod  String?       @map("request_method")
  createdAt      DateTime      @default(now()) @map("created_at")
  adminUser      AdminUser?    @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  session        AdminSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([adminUserId])
  @@index([emailAttempted])
  @@index([eventType])
  @@index([result])
  @@index([ipAddress])
  @@index([sessionId])
  @@map("admin_login_logs")
}
